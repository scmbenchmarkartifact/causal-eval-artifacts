  "@type": "sc:Dataset",
  "name": "Anonymous Causal SCM Benchmark",
  "description": "Synthetic finite Boolean structural-causal-mechanism benchmark for evaluating causal mechanism induction from interventional observations. The release contains frozen runtime benchmark YAML files plus executable prompt export, scoring, report replay, and paper-result validation code.",
  "conformsTo": "http://mlcommons.org/croissant/1.1",
  "citeAs": "Anonymous Authors. Anonymous Causal SCM Benchmark. NeurIPS 2026 review artifact.",
  "datePublished": "2026-05-03",
  "isLiveDataset": false,
  "keywords": [
    "causal reasoning",
    "structural causal models",
    "benchmark",
    "evaluation",
    "synthetic data"
  ],
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "prov:wasDerivedFrom": "Not derived from external datasets; generated synthetically from finite Boolean SCM specifications.",
  "prov:wasGeneratedBy": "Synthetic benchmark construction pipeline described in the submitted paper; reviewer-facing artifact includes frozen outputs and executable scoring/validation code.",
  "rai:dataAnnotationProtocol": "Gold mechanisms and held-out outcomes are generated by the benchmark construction pipeline; no human annotation is used.",
  "rai:dataBiases": "The data distribution is synthetic and intentionally constrained to finite Boolean SCMs, so it over-represents symbolic causal mechanism induction tasks relative to open-world scientific causal discovery.",
  "rai:dataCollection": "Synthetic benchmark instances generated from finite Boolean structural causal mechanisms.",
  "rai:dataCollectionType": "Synthetic data generation",
  "rai:dataLimitations": [
    "Synthetic finite Boolean SCMs are controlled stress tests and should not be interpreted as direct measurements of real-world causal discovery from observational scientific data.",
    "The minimal anonymous artifact does not include live LLM provider runners; reviewers can export prompts and score externally generated predictions."
  ],
  "rai:dataPreprocessingProtocol": "Frozen runtime files are released as YAML snapshots; no reviewer-side benchmark generation is required.",
  "rai:dataReleaseMaintenancePlan": "The anonymous review artifact is publicly accessible at submission time and will be updated for final submission/camera-ready release as required by NeurIPS.",
  "rai:dataSocialImpact": "The benchmark may improve transparency around causal-reasoning claims in AI systems. Misuse risks include overgeneralizing performance on synthetic Boolean tasks to real-world causal discovery settings; documentation and paper limitations call out this boundary.",
  "rai:dataUseCases": [
    "Evaluation and stress testing of causal mechanism induction systems from interventional observations.",
    "Auditing train-to-heldout generalization and identifiability behavior for language-model and symbolic reasoning systems."
  ],
  "rai:hasSyntheticData": true,
  "rai:machineAnnotationTools": "Deterministic SCM simulator and evaluator described in the submitted paper.",
  "rai:personalSensitiveInformation": "The dataset contains synthetic Boolean variables only and no personal or sensitive information.",
